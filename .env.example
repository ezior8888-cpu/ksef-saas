# ═══════════════════════════════════════════════════════════════
# KSEF SAAS — przykładowe zmienne środowiskowe
# ═══════════════════════════════════════════════════════════════
# INSTRUKCJA: skopiuj ten plik do `.env.local` i wypełnij prawdziwymi wartościami.
# NIGDY nie commituj `.env.local` do Gita.

# ═══════════════════════════════════════════════════════════════
# NEXT.JS — podstawy
# ═══════════════════════════════════════════════════════════════

# Publiczny URL aplikacji. Lokalnie http://localhost:3000, produkcja np. https://ksefsaas.pl
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Środowisko aplikacji: development / staging / production
NEXT_PUBLIC_APP_ENV=development


# ═══════════════════════════════════════════════════════════════
# SUPABASE (Faza 2)
# Znajdziesz w: https://supabase.com/dashboard/project/_/settings/api
# ═══════════════════════════════════════════════════════════════

# URL projektu (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publiczny klucz ANON (bezpieczny do użycia w przeglądarce)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxx

# Tajny klucz service role (TYLKO na serwerze, OBCHODZI RLS - uważaj!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxx

# Opcjonalnie: connection string Postgres (Direct, :5432) — tylko do `pnpm db:push:prod`
# (migracje na wybraną bazę). Dashboard → Settings → Database → URI.
# NIE używaj tego w kodzie Next — tylko w CLI.
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[HASŁO]@db.[ref].supabase.co:5432/postgres


# ═══════════════════════════════════════════════════════════════
# NEXTAUTH.JS / AUTH.JS (Faza 2)
# ═══════════════════════════════════════════════════════════════

# Losowy sekret do podpisywania JWT (wygeneruj: `openssl rand -base64 32`)
AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL aplikacji (ten sam co NEXT_PUBLIC_APP_URL)
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
AUTH_GOOGLE_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
# KSEF API (Faza 3)
# ═══════════════════════════════════════════════════════════════

# Środowisko: test / production
# UWAGA: w trakcie developmentu ZAWSZE 'test'. Production dopiero po pełnych testach.
KSEF_ENV=test

# Bazowe URL-e API (pozostaw te wartości; przełączamy przez KSEF_ENV)
KSEF_TEST_URL=https://ksef-test.mf.gov.pl
KSEF_PROD_URL=https://ksef.mf.gov.pl

# Klucz szyfrujący credentials KSeF w bazie (wygeneruj: `openssl rand -base64 32`)
KSEF_CREDENTIALS_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ═══════════════════════════════════════════════════════════════
# INNGEST (Faza 5)
# Znajdziesz w: https://app.inngest.com/env/production/manage/signing-key
# ═══════════════════════════════════════════════════════════════

# Lokalnie zostaw puste (Inngest dev server)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# ═══════════════════════════════════════════════════════════════
# CLOUDFLARE R2 (Faza 4)
# Znajdziesz w: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
# ═══════════════════════════════════════════════════════════════

R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=ksef-saas-xml-dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev


# ═══════════════════════════════════════════════════════════════
# AWS S3 GLACIER (Faza 7 / compliance)
# Znajdziesz w: AWS Console → IAM → Users → Security credentials
# ═══════════════════════════════════════════════════════════════

AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Preferowana nazwa (kod); jeśli pusta, używane jest AWS_GLACIER_BUCKET.
AWS_ARCHIVE_BUCKET=ksef-saas-archive-prod
AWS_GLACIER_BUCKET=ksef-saas-archive-prod


# ═══════════════════════════════════════════════════════════════
# SENTRY (Faza 8 — monitoring błędów)
# Dashboard: https://sentry.io → Project → Client Keys (DSN)
# ═══════════════════════════════════════════════════════════════
#
# Serwer / Edge (instrumentation.ts → sentry.server.config.ts)
SENTRY_DSN=
#
# Klient (instrumentation-client.ts — NEXT_PUBLIC_* trafia do bundle)
NEXT_PUBLIC_SENTRY_DSN=
#
# Opcjonalnie: to samo co VERCEL_ENV na kliencie (production / preview)
# — jeśli puste, Sentry użyje NODE_ENV z builda.
NEXT_PUBLIC_VERCEL_ENV=
#
# Upload source maps przy `next build` (Vercel: Settings → Env → Build)
# https://docs.sentry.io/platforms/javascript/guides/nextjs/manual-setup/#step-4-add-readable-stack-traces-with-source-maps-optional
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
#
# Opcjonalnie: tajny token do GET /api/sentry-test-log?token=... (tylko production)
SENTRY_LOG_TEST_SECRET=


# ═══════════════════════════════════════════════════════════════
# GUS/REGON API (Faza 6 — wyszukiwarka kontrahentów po NIP)
# Rejestracja: https://api.stat.gov.pl/Home/RegonApi
# ═══════════════════════════════════════════════════════════════

GUS_API_KEY=xxxxxxxxxxxxxxxxxxxxx
GUS_API_URL=https://wyszukiwarkaregon.stat.gov.pl/wsBIR/UslugaBIRzewnPubl.svc


# ═══════════════════════════════════════════════════════════════
# EMAIL (powiadomienia — Resend, Faza 5 + Faza 26)
# Dashboard: https://resend.com → Domains + Webhooks
# ═══════════════════════════════════════════════════════════════

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=no-reply@ksefsaas.pl

# Faza 26: separacja transactional vs marketing (różne subdomeny żeby
# marketing complaint nie zniszczył reputacji subdomeny transactional).
# Format: 'Nazwa <adres@subdomena.tld>'.
# Brak = fallback do RESEND_FROM_EMAIL (lub EMAIL_FROM).
RESEND_FROM_TRANSACTIONAL=FaktFlow <no-reply@app.faktflow.pl>
RESEND_FROM_MARKETING=FaktFlow <hello@hello.faktflow.pl>

# Faza 26: Resend webhook (bounce + complaint handling).
# Setup: Resend Dashboard → Webhooks → Add endpoint:
#   URL: https://app.faktflow.pl/api/email/resend-webhook
#   Events: email.bounced, email.complained, email.delivery_delayed
# Resend zwraca `whsec_<base64>` — wklej całość włącznie z prefixem.
RESEND_WEBHOOK_SECRET=

# Faza 26: HMAC secret dla one-click unsubscribe tokens (RFC 8058).
# Minimum 32 znaki random. Wygeneruj: `openssl rand -hex 32` lub
# `node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"`.
# Zmiana tego secret = wszystkie stare linki unsubscribe przestają działać.
EMAIL_UNSUBSCRIBE_SECRET=


# ═══════════════════════════════════════════════════════════════
# WEB PUSH — VAPID (Faza 17, PWA)
# Parę kluczy: npx web-push generate-vapid-keys
# https://web.dev/articles/push-notifications-web-push-protocol
# NEXT_PUBLIC_* = klucz publiczny w bundle (subscribe w przeglądarce).
# VAPID_SUBJECT = kontakt do administratora (mailto: lub https:); wiele hostów używa mailto:
# ═══════════════════════════════════════════════════════════════

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=kontakt@faktflow.pl


# ═══════════════════════════════════════════════════════════════
# ANTHROPIC (Faza 18 — OCR / Vision, Messages API)
# Klucz: https://console.anthropic.com/settings/keys
# Model: ID z dokumentacji Messages (np. vision-capable Sonnet).
# ═══════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=
ANTHROPIC_OCR_MODEL=claude-3-5-sonnet-20241022

# ═══════════════════════════════════════════════════════════════
# ADMIN PANEL (Faza 24)
# Lista emaili adminów platformy (Ty + kolega). Comma-separated.
# Brak ustawienia = brak adminów = /admin/* całkowicie zablokowane.
# Zmiana wymaga redeploy Vercel (env var → restart Next.js).
# ═══════════════════════════════════════════════════════════════
ADMIN_EMAILS=

# ═══════════════════════════════════════════════════════════════
# UPSTASH REDIS (Faza 22 — cache layer)
# Konto: https://upstash.com (free tier, EU region Frankfurt).
# Bez tych zmiennych cache jest fail-soft (aplikacja działa bez Redisa).
# ═══════════════════════════════════════════════════════════════
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════════════
# VERCEL EDGE CONFIG (Faza 22 — global feature flags / kill-switches)
# Setup: Vercel dashboard → Project → Edge Config → Connect.
# Brak = global flags traktowane jako FALSE.
# ═══════════════════════════════════════════════════════════════
EDGE_CONFIG=

# ═══════════════════════════════════════════════════════════════
# STRIPE (Faza 25 — billing)
# Setup: https://dashboard.stripe.com/test/apikeys
# Webhook: https://app.faktflow.pl/api/stripe/webhook (production)
# Eventy do subskrybowania:
#   - customer.subscription.created/updated/deleted
#   - invoice.payment_succeeded / payment_failed
#   - customer.subscription.trial_will_end
# Price IDs: utwórz w Stripe Dashboard → Products (monthly + annual w PLN).
# ═══════════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Self-invoicing (Faza 25 Krok 4): UUID naszego tenanta w `tenants` table.
# Po `payment_succeeded` nasza apka wystawia fakturę VAT przez własny KSeF
# pipeline — operator = FaktFlow, nabywca = klient.
# Pusty = self-invoicing wyłączony (Stripe receipts jako fallback).
FAKTFLOW_OPERATOR_TENANT_ID=
# Numer konta bankowego operatora (na fakturze VAT). Opcjonalny.
FAKTFLOW_OPERATOR_BANK_ACCOUNT=