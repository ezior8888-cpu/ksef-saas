  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:vitest",
    "ksef:test-auth": "tsx scripts/test-ksef-auth.ts",
    "ksef:test-token": "tsx scripts/test-ksef-token.ts",
