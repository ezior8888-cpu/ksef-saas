    "db:push:prod:dry": "node scripts/supabase-push-production.mjs --dry-run",
    "test:phase5": "tsx scripts/test-phase5-jobs.ts",
    "inngest:dev": "inngest-cli dev",
    "test": "tsx --test lib/xml/invoice-calculator.test.ts lib/xml/fa3-generator.test.ts lib/xml/validator.test.ts",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:rls": "vitest run tests/rls-isolation.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps chromium firefox webkit",
    "test:all": "pnpm test && pnpm test:vitest"
