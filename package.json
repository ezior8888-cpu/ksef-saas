{
  "name": "ksef-saas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run test:vitest",
    "ksef:test-auth": "tsx scripts/test-ksef-auth.ts",
    "ksef:test-token": "tsx scripts/test-ksef-token.ts",
    "ksef:submit-full": "tsx scripts/test-submit-full.ts",
    "r2:smoke": "tsx scripts/test-r2.ts",
    "fa3:test": "tsx scripts/test-fa3-generation.ts",
    "seed:tenant": "tsx scripts/seed-tenant.ts",
    "seed:invoice": "tsx scripts/seed-test-invoice.ts",
    "trigger:submit": "tsx scripts/trigger-submit.ts",
    "db:push:prod": "node scripts/supabase-push-production.mjs",
    "db:push:prod:dry": "node scripts/supabase-push-production.mjs --dry-run",
    "test:phase5": "tsx scripts/test-phase5-jobs.ts",
    "inngest:dev": "inngest-cli dev",
    "test": "tsx --test lib/xml/invoice-calculator.test.ts lib/xml/fa3-generator.test.ts lib/xml/validator.test.ts",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:rls": "vitest run tests/rls-isolation.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps chromium firefox webkit",
    "test:all": "pnpm test && pnpm test:vitest",
    "load:smoke": "bash scripts/k6-run.sh load-tests/smoke.js",
    "load:run": "bash scripts/k6-run.sh load-tests/main.js",
    "load:dashboard": "bash scripts/k6-run.sh load-tests/scenarios/dashboard-viewer.js",
    "load:invoice": "bash scripts/k6-run.sh load-tests/scenarios/invoice-issuer.js",
    "load:ocr": "bash scripts/k6-run.sh load-tests/scenarios/ocr-scanner.js",
    "load:bulk": "bash scripts/k6-run.sh load-tests/scenarios/bulk-importer.js",
    "load:stress:db": "bash scripts/k6-run.sh load-tests/stress/db-stress.js",
    "load:stress:ksef": "bash scripts/k6-run.sh load-tests/stress/ksef-queue.js",
    "load:stress:ocr": "bash scripts/k6-run.sh load-tests/stress/ocr-pipeline.js",
    "perf:lighthouse": "lighthouse --budget-path=load-tests/lighthouse-budget.json --only-categories=performance --chrome-flags=\"--headless\"",
    "verify:fa3": "tsx scripts/verify-fa3-all-types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@peculiar/webcrypto": "^1.5.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/nextjs": "^10.53.1",
    "@serwist/next": "^9.5.11",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@upstash/redis": "^1.38.0",
    "@vercel/edge-config": "^1.4.3",
    "@xmldom/xmldom": "^0.9.10",
    "archiver": "^7.0.1",
    "bir1": "^4.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.7.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "iconv-lite": "^0.7.2",
    "inngest": "^4.4.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "p-queue": "^9.1.2",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "posthog-js": "^1.374.2",
    "posthog-node": "^5.34.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "resend": "^6.12.0",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "xadesjs": "^2.6.7",
    "xml-core": "^1.2.5",
    "xml-crypto": "^6.1.2",
    "xmlbuilder2": "^4.0.3",
    "xmllint-wasm": "^5.2.0",
    "zod": "^4.3.6"
  },
  "browserslist": [
    "chrome >= 110",
    "edge >= 110",
    "firefox >= 110",
    "safari >= 16",
    "not dead"
  ],
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/archiver": "^7.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@types/xml-crypto": "^1.4.6",
    "@vitest/ui": "^4.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "inngest-cli": "^1.17.9",
    "serwist": "^9.5.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@xmldom/xmldom": "0.9.10"
      }
    },
    "onlyBuiltDependencies": [
      "inngest-cli"
    ],
    "overrides": {
      "@grpc/proto-loader>protobufjs": ">=8.6.0",
      "@aws-sdk/xml-builder>fast-xml-parser": ">=5.7.0",
      "fast-uri@<3.1.1": ">=3.1.1",
      "fast-xml-builder@<1.1.7": ">=1.1.7",
      "hono@<4.12.21": ">=4.12.21",
      "ip-address@<10.1.1": ">=10.1.1",
      "postcss@<8.5.10": ">=8.5.10",
      "protobufjs@<8.6.0": ">=8.6.0",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "tmp@<0.2.6": ">=0.2.6",
      "uuid@<11.1.1": ">=11.1.1",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "@protobufjs/utf8@<1.1.1": ">=1.1.1",
      "@opentelemetry/auto-instrumentations-node@<0.75.0": ">=0.75.0",
      "@opentelemetry/sdk-node@<0.217.0": ">=0.217.0",
      "@opentelemetry/exporter-prometheus@<0.217.0": ">=0.217.0",
      "@opentelemetry/core@>=2.0.0 <2.8.0": ">=2.8.0",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
      "dompurify@>=3.0.0 <3.4.11": ">=3.4.11",
      "tar@>=7.0.0 <7.5.16": ">=7.5.16",
      "js-yaml@>=3.0.0 <3.15.0": ">=3.15.0 <4",
      "js-yaml@>=4.0.0 <4.2.0": ">=4.2.0 <5",
      "@babel/core@>=7.0.0 <7.29.6": ">=7.29.6 <8",
      "adm-zip@<0.6.0": ">=0.6.0"
    }
  }
}
